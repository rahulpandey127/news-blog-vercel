<div id="admin-content">
  <div class="container">
    <div class="row">
      <div class="col-md-10">
        <h1 class="admin-heading">
          <i class="fa fa-file-text"></i> All Articles
        </h1>
      </div>
      <div class="col-md-2">
        <a class="add-new" href="/admin/add-article">Add New Article</a>
      </div>

      <div class="col-md-12">
        <div id="articlesTable"></div>
      </div>
    </div>
  </div>
</div>

<script
  type="text/javascript"
  src="https://unpkg.com/tabulator-tables@6.3.1/dist/js/tabulator.min.js"
></script>

<script>

     let dataTable= <%-JSON.stringify(articles)%>

     var table = new Tabulator("#articlesTable", {
       data:dataTable,
       layout:"fitColumns",
       pagination:"true",
       paginationSize:10,
       paginationSizeSelector:[5, 10, 25, 50, 100],
       columns:[
          {title:"S.No.", formatter:"rownum", width:100,hozAlign:"center"},
          {title:"Title", field:"title", headerFilter:"input"},
          {title:"Category name", field:"category.name", headerFilter:"input"},
           {title:"Author", field:"author.fullname", headerFilter:"input"},
          {title:"DATE", field:"createdAt", headerFilter:"input",formatter:function(cell, formatterParams, onRendered){
            var dateOptions = { year: 'numeric', month: 'long', day: '2-digit' };
            var formattedDate = new Intl.DateTimeFormat('en-GB', dateOptions).format(new Date(cell.getValue()));
            return formattedDate;
              return date.toLocaleDateString();
          }},

          {title:"Actions",formatter:function(cell, formatterParams, onRendered){
              return `<a href="/admin/update-article/${cell.getData()._id}" class="btn btn-sm btn-success">Edit</a>
              <button class="btn btn-sm btn-danger delete-article" onClick="deleteArticle('${cell.getData()._id}')">Delete</button>`
          }},
       ],
   });

  async function deleteArticle(id){
    console.log(id);
     try{
      if(confirm("Are you sure you want to delete this Article?")){
        let response= await fetch(`/admin/delete-article/${id}`,{method:"delete"});
        if(response.ok){
          window.location.reload();
        }
      }
     }catch(err){
       console.log(err);
   }}
</script>

